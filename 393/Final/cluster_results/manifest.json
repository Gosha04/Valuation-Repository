{
  "splits": [
    "train",
    "validation",
    "test"
  ],
  "sample_size": 25000,
  "seed": 393,
  "labels_path": "Final/cluster_results/clustered_responses.parquet",
  "reduced_embeddings_path": "Final/cluster_results/reduced_embeddings.npy",
  "summary_json_path": "Final/cluster_results/cluster_summary.json",
  "summary_markdown_path": "Final/cluster_results/cluster_summary.md",
  "reduction": {
    "input_shape": [
      25000,
      384
    ],
    "pca": {
      "dims": 50,
      "explained_variance_ratio_sum": 0.5570545196533203
    },
    "umap": {
      "dims": 15,
      "metric": "cosine"
    },
    "output_shape": [
      25000,
      15
    ]
  },
  "clustering": {
    "algorithm": "hdbscan",
    "min_cluster_size": 35,
    "min_samples": 5,
    "cluster_count": 2,
    "noise_count": 0,
    "noise_fraction": 0.0
  }
}
